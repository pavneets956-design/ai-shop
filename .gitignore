# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — NEVER commit (contain API keys / secrets)
.env*.local
.env
# plain-text env dumps that don't match the .env* patterns (e.g. env.local.txt)
env.local.txt
env*.txt
*.local.txt
*secret*.txt
*apikey*.txt

# vercel
.vercel

# superpowers brainstorming mockups (local only)
/.superpowers/

# playwright / browser-automation session artifacts
/.playwright-mcp/
/gsc-state.png

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma — migrations MUST be committed (build runs `prisma migrate deploy`)


# Root QA / design screenshots (local only)
/*.png
/*.jpeg

# graphify knowledge graph artifacts (regenerated locally)
graphify-out/

# local agent config / transcripts (never commit — may contain secrets)
.claude/
